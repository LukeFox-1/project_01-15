# ╔═╡ 0ae7e576-5c31-4ec7-bd4e-6df4b41c7c4f
function compute_pendulum_trajectory(sol, p)
    θ_vals = sol[θ_s]
    t_vals = sol.t
    Ω_val = p[Ω]
    L_val = p[L]
    w_val = p[w1]
    h_val = p[h1]
    
    φ_vals = Ω_val .* t_vals
    
    # Position in inertial frame
    r_x = L_val .* sin.(θ_vals) .* cos.(φ_vals) .+ w_val .* cos.(φ_vals)
    r_y = L_val .* sin.(θ_vals) .* sin.(φ_vals) .+ w_val .* sin.(φ_vals)
    r_z = h_val .- L_val .* cos.(θ_vals)
    
    # Pivot position
    pivot_x = w_val .* cos.(φ_vals)
    pivot_y = w_val .* sin.(φ_vals)
    pivot_z = fill(h_val, length(t_vals))
    
    max_radius = L_val + w_val
    
    return (; t_vals, r_x, r_y, r_z, 
            pivot_x, pivot_y, pivot_z, 
            max_radius, h_val, L_val, w_val)
end

# ╔═╡ fcd29939-01e8-42ae-8fef-f70ca60eebef
function animate_pendulum_3d(solution, parameters; 
                              title="3D Pendulum on Rotating Frame", 
                              filename="pendulum_3d.gif", 
                              fps=30,
                              every_n=3)
    
    geom = compute_pendulum_trajectory(solution, parameters)
    
    anim = @animate for i in 1:every_n:length(geom.t_vals)
        # Static vertical frame
        vert_x = [0.0, 0.0]
        vert_y = [0.0, 0.0]
        vert_z = [0.0, geom.h_val]
        
        # Rotating arm
        arm_x = [0.0, geom.pivot_x[i]]
        arm_y = [0.0, geom.pivot_y[i]]
        arm_z = [geom.h_val, geom.pivot_z[i]]
        
        # Pendulum rod
        rod_x = [geom.pivot_x[i], geom.r_x[i]]
        rod_y = [geom.pivot_y[i], geom.r_y[i]]
        rod_z = [geom.pivot_z[i], geom.r_z[i]]
        
        # Trace of bob path
        trace_x = geom.r_x[1:i]
        trace_y = geom.r_y[1:i]
        trace_z = geom.r_z[1:i]
        
        plot3d(trace_x, trace_y, trace_z,
               label="Trace", linecolor=:blue, linewidth=1, linestyle=:dot,
               xlim=(-geom.max_radius, geom.max_radius),
               ylim=(-geom.max_radius, geom.max_radius),
               zlim=(0.0, geom.h_val + geom.L_val + 0.1),
               aspect_ratio=:equal,
               xlabel="x (m)", ylabel="y (m)", zlabel="z (m)",
               title="$title (t = $(round(geom.t_vals[i]; digits=2)) s)",
               legend=false)
        
        plot3d!(rod_x, rod_y, rod_z,
                linecolor=:green, linewidth=3, label="Pendulum")
        scatter3d!([geom.r_x[i]], [geom.r_y[i]], [geom.r_z[i]],
                   markercolor=:red, markersize=8, label="Bob")
        plot3d!(vert_x, vert_y, vert_z,
                linecolor=:black, linewidth=3, label="Frame")
        plot3d!(arm_x, arm_y, arm_z,
                linecolor=:black, linewidth=3, label="Rotating Arm")
        scatter3d!([geom.pivot_x[i]], [geom.pivot_y[i]], [geom.pivot_z[i]],
                   markercolor=:orange, markersize=5, label="Pivot")
    end
    
    gif(anim, filename, fps=fps)
end

