# ╔═╡ f17103ea-06bf-11f1-a2b0-79e68ed152eb
md"""# Project_01 - Spinning Pendulum and the Lagrange equations

In this project, a pendulum is attached to a spinning frame. The frame has dimensions, 

$h_1 = 0.2~m$

$w_1 = 0.1~m$

and the pendulum length is $L=0.15~m$ with a $m=0.1~kg$ point mass at the end of the system. The pendulum swings in the $x'-z'-plane$ as it rotates at a constant speed, $\Omega$

![Spinning pendulum with rotating and fixed coordinate systems.](https://raw.githubusercontent.com/cooperrc/me5180-project_01/refs/heads/main/spinning_pendulum.svg)

Your team's goal is to 

- build the equations of motion using Lagrange and least action $L=T-V$
- solve for the motion for a slow rotation speed and a fast rotation speed
- visualize the solution with plots and animations
"""

# ╔═╡ 62863f20-5275-4851-acba-53e83652e60a
function dot_product(a, b) 
    return sum(a .* b)
end

# ╔═╡ e98da86e-fd61-4c61-a386-b84b12629a1a
function magnitude(a) 
    return sqrt(dot_product(a,a))
end

# ╔═╡ 91003e71-8208-43d3-93be-dd2c141c37b5
md"""# Defining the Coordinate System

We start by defining our coordinate systems. The first coordinate system $XYZ$ is the inertial reference frame, with the origin at the bottom of the pendulum frame. The second coordinate system $X'Y'Z'$ rotates with the frame, with its origin at the top of the vertical segment (height $h_1$).

The angle $\theta(t)$ is measured from the vertical in the rotating frame.

The frame rotates at constant speed $\Omega$, so $\phi(t) = \Omega t$ is not a degree of freedom.

We have only **1 DOF**: $\theta$.
"""

# ╔═╡ 910c7d40-5d28-448e-aaf7-486bb000f478
begin
    # Define symbolic variables
    @parameters L h1 w1 m g Ω
    @independent_variables t
    @variables θ(t)
    
    D = Differential(t)
    θ_dot = D(θ)
    θ_dot_dot = D(D(θ))
    φ = Ω * t
end

# ╔═╡ e28f72c0-7df2-4029-ab2a-4f21f2bade62
md"""
The position of the mass in the inertial frame is:

$\vec{r} = \vec{R} + A \vec{u}$

Where:
- $\vec{R} = [0, 0, h_1]^T$ is the fixed pivot point
- $A$ is the z-axis rotation matrix for angle $\phi = \Omega t$
- $\vec{u} = [w_1 + L\sin\theta, 0, -L\cos\theta]^T$ is the position in the rotating frame

$A = \begin{bmatrix} 
\cos(\phi) & -\sin(\phi) & 0 \\ 
\sin(\phi) & \cos(\phi) & 0 \\
0 & 0 & 1 \end{bmatrix}$
"""

# ╔═╡ 4aa26d4b-953f-4f55-8ba7-86e16ef8e788
begin
    # Position vectors
    R = [0; 0; h1]
    u = [w1 + L*sin(θ); 0; -L*cos(θ)]
    A = [cos(φ) -sin(φ) 0; sin(φ) cos(φ) 0; 0 0 1]
    r = R + A * u
end

# ╔═╡ a78fdfa3-31ad-4cf6-b97e-10d0036477d7
begin
    # Physical constants
    h1_val = 0.2      # m - frame height
    w1_val = 0.1      # m - frame offset
    L_val  = 0.15     # m - pendulum length
    m_val  = 0.1      # kg - mass
    g_val  = 9.81     # m/s^2 - gravity

    # Rotation speeds
    Ω_slow = 2.0      # rad/s - slow rotation
    Ω_fast = 10.0     # rad/s - fast rotation
    Ω_very_fast = 16.0 # rad/s - very fast rotation
    Ω_no_rotation = 0.0 # rad/s - no rotation
end

# ╔═╡ 2c97d2eb-070c-499f-8bbc-9f650953ccd1
md"""
# Computing the Lagrangian

$L = T - V$ where:

- $T = \frac{1}{2}m \vec{v} \cdot \vec{v}$ (kinetic energy)
- $V = mgz$ (potential energy, with $z=0$ as reference)
"""

# ╔═╡ 61500b9e-061e-4412-9fa7-9931ad27bee4
begin
    # Velocity and Lagrangian
    v = D.(r)
    T = m/2 * dot_product(v, v)
    V = m * g * r[3]
    Lag = expand_derivatives(T - V)
end

# ╔═╡ 850f64b5-841b-4898-8bab-de2bcc206728
md"""
## Euler-Lagrange Equation

$\frac{d}{dt}\left( \frac{\partial L}{\partial \dot{\theta}} \right) - \frac{\partial L}{\partial \theta} = 0$
"""

# ╔═╡ 242302eb-fe7e-4c20-83a2-f5a976fbbac9
begin
    # Euler-Lagrange derivatives
    dL_dθ = Symbolics.derivative(Lag, θ)
    dL_dθ_dot = Symbolics.derivative(Lag, θ_dot)
    
    # Equation of motion
    EL_eq = expand_derivatives(D(dL_dθ_dot) - dL_dθ)
    
    # Solve for θ̈
    θddot_expr = Symbolics.solve_for(EL_eq ~ 0, θ_dot_dot)
    θddot_simplified = Symbolics.simplify(θddot_expr)
end

# ╔═╡ a8c3fe2c-0ef9-4109-8c1a-b547e33116a7
md"""
The resulting equation of motion is:

$\ddot{\theta} = \Omega^{2} \sin\theta \cos\theta - \frac{g}{L}\sin\theta$
"""

# ╔═╡ 28406b28-a701-4b46-8620-5df4a5dc70ae
begin
    # Set up ODE system for numerical solution
    @variables θ_s(t) ω_s(t)
    
    rhs_expr = substitute(θddot_simplified, Dict(θ => θ_s, θ_dot => ω_s))
    
    eqs = [
        D(θ_s) ~ ω_s,
        D(ω_s) ~ rhs_expr
    ]
    
    @named sys = ODESystem(eqs, t, [θ_s, ω_s], [L, g, Ω, w1, h1, m])
    sys = structural_simplify(sys)
end

# ╔═╡ 44d9e415-a7ac-431c-a72e-0d4392b2e629
function simulate_pendulum(sys; 
                           L_val=0.15, g_val=9.81, Ω_val=2.0, 
                           w1_val=0.1, h1_val=0.2, m_val=0.1,
                           θ0=0.2, ω0=0.0,
                           tspan=(0.0, 20.0))
    
    u0 = Dict(θ_s => θ0, ω_s => ω0)
    p = Dict(L => L_val, g => g_val, Ω => Ω_val, 
             w1 => w1_val, h1 => h1_val, m => m_val)
    
    prob = ODEProblem(sys, merge(u0, p), tspan)
    sol = solve(prob, Tsit5(); reltol=1e-6, abstol=1e-8, saveat=0.05)
    
    return sol, p
end

# ╔═╡ 8776d0cc-f9fb-43ee-babe-b77ec4f189ce
begin
    # Simulate for different rotation speeds
    sol_no_rotation, p_no = simulate_pendulum(sys; Ω_val=Ω_no_rotation)
    sol_slow, p_slow = simulate_pendulum(sys; Ω_val=Ω_slow)
    sol_fast, p_fast = simulate_pendulum(sys; Ω_val=Ω_fast)
    sol_very_fast, p_very_fast = simulate_pendulum(sys; Ω_val=Ω_very_fast)
    
    md"Simulations complete for all rotation speeds"
end

